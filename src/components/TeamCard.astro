---
import { getYouthAgeGroup, currentSeason } from "../data/teams";

const { team } = Astro.props;

const ageGroup = team.birthYear ? getYouthAgeGroup(team.birthYear) : null;
---

<a
  href={`/team/${team.slug}`}
  class="group block rounded-2xl border border-white/10 bg-white/5 p-6 transition hover:-translate-y-1 hover:bg-white/10"
>
  <div class="flex items-start justify-between gap-4">
    <div>
      {ageGroup && (
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-blue-300">
          {ageGroup} • {currentSeason.label}
        </p>
      )}

      <h2 class="mt-3 text-2xl font-semibold text-white">
        {team.teamName}
      </h2>
    </div>

    {team.recruiting && (
      <span class="rounded-full bg-blue-500/20 px-3 py-1 text-xs font-semibold text-blue-200">
        Recruiting
      </span>
    )}
  </div>

  <p class="mt-4 text-slate-300">
    {team.description}
  </p>
{team.sponsorName && (
  <div class="mt-6 rounded-2xl border border-white/10 bg-white/5 p-4">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-300">
      Team Sponsor
    </p>

    <div class="mt-3 flex items-center justify-between gap-4">
      <p class="font-semibold text-white">
        {team.sponsorName}
      </p>

      {team.sponsorLogo && (
        <div class="rounded-2xl bg-white/95 p-3 shadow-lg shadow-black/10">
          <img
            src={team.sponsorLogo}
            alt={`${team.sponsorName} logo`}
            class="h-16 w-auto object-contain"
          />
        </div>
      )}
    </div>
  </div>
)}
  <p class="mt-6 font-semibold text-blue-300 transition group-hover:text-blue-200">
  {
    team.section === "sessional-football"
      ? "View sessions →"
      : "View team →"
  }
</p>
</a>