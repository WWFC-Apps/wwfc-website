---
const { team } = Astro.props;
---

<a
  href={`/team/${team.slug}`}
  class="group block rounded-2xl border border-white/10 bg-white/5 p-6 transition hover:-translate-y-1 hover:bg-white/10"
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-blue-300">
        {team.ageGroup}
      </p>
      <h2 class="mt-3 text-2xl font-semibold text-white">
        {team.name}
      </h2>
    </div>

    {team.recruiting && (
      <span class="rounded-full bg-blue-500/20 px-3 py-1 text-xs font-semibold text-blue-200">
        Recruiting
      </span>
    )}
  </div>
  

  <p class="mt-4 text-slate-300">
    {team.description}
  </p>

  <dl class="mt-6 space-y-2 text-sm text-slate-400">
    <div>
      <dt class="inline font-semibold text-slate-200">Manager:</dt>
      <dd class="inline"> {team.manager}</dd>
    </div>
    <div>
      <dt class="inline font-semibold text-slate-200">Training:</dt>
      <dd class="inline"> {team.training}</dd>
    </div>
  </dl>

  <p class="mt-6 font-semibold text-blue-300 group-hover:text-blue-200">
    View team →
  </p>
</a>