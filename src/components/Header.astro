---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/teams", label: "Teams" },
  { href: "/visiting-teams", label: "Visiting Teams" },
  { href: "/policies", label: "Policies" },
  { href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-[#04163a]/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
<a href="/" class="flex items-center gap-3 font-bold">
  <img
    src="/images/wwfc-logo.png"
    alt="Wroughton & Wichelstowe FC logo"
    class="h-16 w-auto rounded-xl bg-white p-1.5 shadow-lg shadow-black/20"
  />
  <span class="hidden sm:inline">Wroughton & Wichelstowe FC</span>
  <span class="sm:hidden">WWFC</span>
</a>

    <nav class="hidden items-center gap-6 text-sm font-medium text-slate-300 md:flex">
      {navItems.map((item) => (
        <a href={item.href} class="hover:text-white">
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href="/contact"
      class="hidden rounded-full bg-blue-500 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-400 sm:inline-flex"
    >
      Join a Team
    </a>
  </div>
</header>