---
import MobileMenu from "./MobileMenu.jsx";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/teams", label: "Teams" },
  { href: "/visiting-teams", label: "Visiting Teams" },
  { href: "/policies", label: "Policies" },
  { href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-[#04163a]/95 backdrop-blur">
  <div class="relative mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
    
    <a href="/" class="flex items-center gap-4 font-bold">
      <img
        src="/images/wwfc-logo.png"
        alt="Wroughton & Wichelstowe FC logo"
        class="h-16 w-auto rounded-xl bg-white p-1.5 shadow-lg shadow-black/20"
      />

      <div class="hidden sm:block">
        <p class="text-lg font-semibold leading-tight text-white">
          Wroughton & Wichelstowe FC
        </p>

        <p class="text-sm font-medium text-blue-300">
          Community Football Club
        </p>
      </div>
    </a>

    <nav class="hidden items-center gap-6 text-sm font-medium text-slate-300 md:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="transition hover:text-white"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href="/contact"
      class="hidden rounded-full bg-blue-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-500/20 transition hover:scale-[1.02] hover:bg-blue-400 md:inline-flex"
    >
      Join a Team
    </a>

    <MobileMenu client:load />
  </div>
</header>