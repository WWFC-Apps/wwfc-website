---
import MobileMenu from "./MobileMenu.jsx";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/teams", label: "Teams" },
  { href: "/news", label: "News" },
  { href: "/visiting-teams", label: "Visiting Teams" },
  { href: "/policies", label: "Policies" },
  { href: "/about/sponsors", label: "Sponsors" },  
  { href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-[#04163a]/95 backdrop-blur">
  <div class="relative mx-auto flex max-w-6xl items-center justify-between gap-6 px-6 py-4">
    <a href="/" class="flex min-w-0 items-center gap-3 font-bold">
      <span class="flex h-16 w-16 shrink-0 items-center justify-center rounded-xl bg-white p-1.5 shadow-lg shadow-black/20">
        <img
          src="/images/wwfc-logo1.png"
          alt="Wroughton & Wichelstowe FC logo"
          class="h-full w-full object-contain"
        />
      </span>

      <span class="hidden min-w-0 sm:block">
        <span class="block text-base font-semibold leading-tight text-white">
          Wroughton & Wichelstowe FC
        </span>
        <span class="block text-xs font-medium text-blue-300">
          Community Football Club
        </span>
      </span>
    </a>

    <nav class="hidden items-center gap-6 text-sm font-medium text-slate-300 md:flex">
      {navItems.map((item) => (
        <a href={item.href} class="transition hover:text-white">
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href="/contact"
      class="hidden shrink-0 rounded-full bg-blue-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-500/20 transition hover:scale-[1.02] hover:bg-blue-400 md:inline-flex"
    >
      Join a Team
    </a>

    <MobileMenu client:load />
  </div>
</header>