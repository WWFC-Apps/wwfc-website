---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "Wroughton & Wichelstowe FC",
  description = "Wroughton & Wichelstowe FC is a registered charity football club providing inclusive football opportunities across Wroughton, Wichelstowe and the surrounding area.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>

  <body class="bg-slate-950 text-white">
    <Header />
    <slot />
    <Footer />
  </body>
</html>