---
import Layout from "../layouts/Layout.astro";
import PageShell from "../components/PageShell.astro";
import { news } from "../data/news";
---

<Layout
  title="News | Wroughton & Wichelstowe FC"
  description="Latest news, announcements and updates from Wroughton & Wichelstowe FC."
>
  <PageShell>
    <section class="py-24">
      <div class="mx-auto max-w-6xl px-6">
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-blue-300">
          Club News
        </p>

        <h1 class="text-5xl font-light tracking-tight sm:text-6xl">
          News & Updates
        </h1>

        <p class="mt-6 max-w-3xl text-lg leading-relaxed text-slate-300">
          Keep up to date with the latest club news, events, tournaments,
          team achievements and announcements from WWFC.
        </p>

        <div class="mt-16 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {news.map((item) => (
            <a
              href={`/news/${item.slug}`}
              class="group flex min-h-[320px] flex-col overflow-hidden rounded-3xl border border-white/10 bg-white/5 transition hover:border-blue-400/40 hover:bg-white/10"
            >
              {item.image && (
                <img
                  src={item.image}
                  alt={item.title}
                  class="h-44 w-full object-contain bg-white/5 p-6"
                />
              )}

              <div class="flex flex-1 flex-col justify-between p-8">
                <div>
                  <p class="text-sm font-semibold text-blue-300">
                    {item.date}
                  </p>

                  <h2 class="mt-3 text-2xl font-semibold text-white transition group-hover:text-blue-300">
                    {item.title}
                  </h2>

                  <p class="mt-4 text-slate-300">
                    {item.summary}
                  </p>
                </div>

                <div class="mt-8 text-sm font-semibold text-blue-300">
                  Read more →
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </PageShell>
</Layout>