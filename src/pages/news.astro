---
import Layout from "../layouts/Layout.astro";
import PageShell from "../components/PageShell.astro";
---

<Layout
  title="News | Wroughton & Wichelstowe FC"
  description="Latest news, announcements and updates from Wroughton & Wichelstowe FC."
>
  <PageShell>
    <section class="py-24">
      <div class="mx-auto max-w-5xl px-6">

        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-blue-300">
          Club News
        </p>

        <h1 class="text-5xl font-light tracking-tight sm:text-6xl">
          News & Updates
        </h1>

        <p class="mt-6 max-w-3xl text-lg leading-relaxed text-slate-300">
          Keep up to date with the latest club news, events, tournaments,
          team achievements and announcements from WWFC.
        </p>

        <div class="mt-16 rounded-3xl border border-white/10 bg-white/5 p-10 text-center">
          <h2 class="text-2xl font-semibold text-white">
            News Section Coming Soon
          </h2>

          <p class="mt-4 text-slate-300">
            We are currently developing the club news section.
            Check back soon for updates, match reports and club announcements.
          </p>
        </div>

      </div>
    </section>
  </PageShell>
</Layout>