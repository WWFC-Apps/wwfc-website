---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";

const sponsors = [
  {
    name: "Ocean Escape.co.uk",
    logo: "/images/sponsors/ocean.png",
    website: "https://www.oceanescape.co.uk",
  },
  {
    name: "A & J Waste Services",
    logo: "/images/sponsors/a&j.jpg",
    website: "https://www.aandjwasteservices.co.uk",
  },
   {
    name: "Southby & Co",
    logo: "/images/sponsors/davesouthby.jpg",
    website: "https://www.southbyfp.co.uk"
  },
  {
    name: "Petshed",
    logo: "/images/sponsors/petshed.png",
    website: "https://www.petshed.co.uk"
  }, 
    {
    name: "MJD Electrical",
    logo: "/images/sponsors/mjd.png",
    website: "https://mjdgroup.co.uk"
  },
    {
    name: "IEW Limited",
    logo: "/images/sponsors/iew.png",
    website: "https://iewlimited.co.uk"
  },
    {
    name: "Hannah McDanielson",
    logo: "/images/sponsors/hannah.webp",
    website: "https://hannahmcdanielsonjewellery.co.uk"
  },
    {
    name: "HeadStart Skillz",
    logo: "/images/sponsors/headstart.png",
    website: "https://www.headstartskillz.co.uk"
  },
     {
    name: "Blackwell Mortgages",
    logo: "/images/sponsors/blackwell.png",
    website: "#"
  },
     {
    name: "TengTools",
    logo: "/images/sponsors/tengtools1.png",
    website: "https://www.tengtools.com/en-gb"
  },
 
      {
    name: "Mem-Star.co.uk",
    logo: "/images/sponsors/memstar.png",
    website: "https://www.mem-star.co.uk"
  },
    {
    name: "Holloway Bond",
    logo: "/images/sponsors/holloway.png",
    website: "https://www.hollowaybond.co.uk"
  },
   {
    name: "Jam Interiors Ltd",
    logo: "/images/sponsors/jam.jpg",
    website: "https://jaminteriorsgroup.com/"
  },
    {
    name: "The Fox & Hounds",
    logo: "/images/sponsors/fox.jpg",
    website: "https://www.thefoxwroughton.com/"
  },
];
---

<Layout
  title="Sponsors | Wroughton & Wichelstowe FC"
  description="Sponsors and community supporters of Wroughton & Wichelstowe FC."
>
  <PageShell>
    <section class="py-24">
      <div class="mx-auto max-w-6xl px-6">

        <a
          href="/about"
          class="text-sm font-semibold text-blue-300 hover:text-blue-200"
        >
          ← Back to About
        </a>

        <div class="mt-10 max-w-4xl">
          <p class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-blue-300">
            Community Support
          </p>

          <h1 class="text-5xl font-light tracking-tight sm:text-6xl">
            Club Sponsors
          </h1>

          <p class="mt-6 text-lg leading-relaxed text-slate-300">
            Wroughton & Wichelstowe FC is able to thrive thanks to the
            dedication of volunteers, community supporters and sponsors.
          </p>

          <p class="mt-4 text-lg leading-relaxed text-slate-300">
            WWFC is proud to be collaborating with the following local businesses
            who help support grassroots football across our community.
          </p>
        </div>

        <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {sponsors.map((sponsor) => (
            <a
              href={sponsor.website}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex min-h-[220px] flex-col items-center justify-center rounded-3xl border border-white/10 bg-white/5 p-8 text-center transition hover:border-blue-400/40 hover:bg-white/10"
            >
           <div class="flex h-32 items-center justify-center rounded-2xl bg-white/95 p-2">
              <img
                src={sponsor.logo}
                alt={sponsor.name}
                class="max-h-28 w-auto object-contain"
              />
            </div>

              <h2 class="mt-6 text-lg font-semibold text-white transition group-hover:text-blue-300">
                {sponsor.name}
              </h2>
            </a>
          ))}
        </div>

      </div>
    </section>
  </PageShell>
</Layout>