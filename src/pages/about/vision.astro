---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
---

<Layout
  title="Club Vision | Wroughton & Wichelstowe FC"
  description="The future vision and strategic direction of Wroughton & Wichelstowe FC."
>
  <PageShell>
    <section class="py-24">
      <div class="mx-auto max-w-4xl px-6">

        <a
          href="/about"
          class="text-sm font-semibold text-blue-300 hover:text-blue-200"
        >
          ← Back to About
        </a>

        <div class="mt-10">
          <p class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-blue-300">
            Future Development
          </p>

          <h1 class="text-5xl font-light tracking-tight sm:text-6xl">
            Club Vision
          </h1>

          <div class="mt-12 rounded-3xl border border-white/10 bg-white/5 p-10 text-center">
            <p class="text-2xl font-light text-white">
              Coming Soon
            </p>

            <p class="mt-4 text-slate-300">
              We are currently preparing our long-term vision and development
              plans for Wroughton & Wichelstowe FC.
            </p>
          </div>

        </div>
      </div>
    </section>
  </PageShell>
</Layout>