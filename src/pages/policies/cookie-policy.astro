---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
---

<Layout
  title="Cookie Policy | Wroughton & Wichelstowe FC"
  description="Cookie Policy for Wroughton & Wichelstowe FC."
>
  <PageShell>
    <section class="py-24">
      <div class="mx-auto max-w-4xl px-6">

        <a
          href="/policies"
          class="text-sm font-semibold text-blue-300 hover:text-blue-200"
        >
          ← Back to Policies
        </a>

        <div class="mt-10">
          <p class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-blue-300">
            Policies
          </p>

          <h1 class="text-5xl font-light tracking-tight sm:text-6xl">
            Cookie Policy
          </h1>

          <div class="mt-10 space-y-6 text-lg leading-relaxed text-slate-300">

            <p>
              This website is operated by Wroughton & Wichelstowe FC (WWFC).
            </p>

            <p>
              Cookies are small text files stored on your device when visiting
              a website. They help websites function correctly and improve the
              user experience.
            </p>

            <h2 class="pt-6 text-2xl font-semibold text-white">
              Cookies We Use
            </h2>

            <p>
              WWFC currently uses only essential website functionality and
              security-related services required for the operation of the site.
            </p>

            <p>
              We do not currently use advertising, marketing or behavioural
              tracking cookies.
            </p>

            <h2 class="pt-6 text-2xl font-semibold text-white">
              Third-Party Services
            </h2>

            <p>
              Some external services linked from this website, including forms
              hosted by third-party providers such as Tally, may use their own
              cookies and privacy technologies. Users should review those
              providers’ privacy policies where appropriate.
            </p>

            <h2 class="pt-6 text-2xl font-semibold text-white">
              Future Updates
            </h2>

            <p>
              If WWFC introduces analytics, embedded media or additional
              third-party services in future, this Cookie Policy will be updated
              accordingly.
            </p>

            <h2 class="pt-6 text-2xl font-semibold text-white">
              Contact
            </h2>

            <p>
              For questions relating to privacy or cookies, please contact the
              club via the Contact page.
            </p>

          </div>
        </div>

      </div>
    </section>
  </PageShell>
</Layout>