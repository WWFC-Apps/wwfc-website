---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Privacy Policy | Wroughton & Wichelstowe FC"
  description="Privacy policy for Wroughton & Wichelstowe FC."
>
  <section class="bg-[#04163a] py-24 text-white">
    <div class="mx-auto max-w-4xl px-6">
      <a
        href="/policies"
        class="text-sm font-semibold text-blue-300 hover:text-blue-200"
      >
        ← Back to policies
      </a>

      <div class="mt-10 rounded-3xl border border-white/10 bg-white/5 p-10">
        <h1 class="text-5xl font-light tracking-tight">
          Privacy Policy
        </h1>

        <p class="mt-6 text-sm text-slate-400">
          Last updated: May 2026
        </p>

        <div class="mt-10 space-y-10 text-slate-300">
          <div>
            <h2 class="text-2xl font-semibold text-white">
              1. Introduction
            </h2>

            <p class="mt-3 leading-relaxed">
              Wroughton & Wichelstowe FC ("WWFC", "we", "our" or "us") is committed
              to protecting and respecting your privacy.
            </p>

            <p class="mt-3 leading-relaxed">
              This policy explains how we collect, use, store and protect personal
              information in accordance with the UK General Data Protection Regulation
              (UK GDPR) and the Data Protection Act 2018.
            </p>
          </div>

          <div>
            <h2 class="text-2xl font-semibold text-white">
              2. Information We Collect
            </h2>

            <ul class="mt-4 list-disc space-y-3 pl-6">
              <li>Name and contact details</li>
              <li>Emergency contact information</li>
              <li>Player registration information</li>
              <li>Medical or accessibility information where required</li>
              <li>Communication preferences</li>
              <li>Website enquiries submitted through contact forms</li>
            </ul>
          </div>

</Layout>