---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import TeamCard from "../../components/TeamCard.astro";
import { teams } from "../../data/teams";

export function getStaticPaths() {
 const sections = [
  "adult-senior-football",
  "youth-football-mixed",
  "girls-football",
  "pan-disability-football",
  "sessional-football",
  "tournament-football",
];
  return sections.map((section) => ({
    params: { section },
  }));
}

const { section } = Astro.params;

const displayNameMap = {
  "adult-senior-football": "Adult / Senior Football",
  "youth-football-mixed": "Youth Football (Mixed)",
  "girls-football": "Girls Football",
  "pan-disability-football": "Pan-Disability Football",
  "sessional-football": "Sessional Football",
  "tournament-football": "Tournament Football",
};

const displayName = displayNameMap[section] ?? "Teams";

const filteredTeams = teams.filter((team) => {
  const teamSection = team.section ?? "";
  return teamSection.toLowerCase().replace(/\s+/g, "-") === section;
});
---

<Layout title={`${displayName} Teams | Wroughton & Wichelstowe FC`}>
<PageShell>
  <section class="mx-auto max-w-6xl px-6 py-20">
      <a href="/teams" class="text-sm font-semibold text-blue-300 hover:text-blue-200">
        ← Back to all sections
      </a>

      <div class="mt-8 flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
  <div>
    <h1 class="text-5xl font-light tracking-tight text-white">
      {displayName}
    </h1>

  <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-300">
  {
    section === "sessional-football"
      ? "Browse WWFC sessional football programmes and participation sessions."
      : `Browse WWFC ${displayName.toLowerCase()} teams and age groups.`
  }
</p>
  </div>
  {section === "sessional-football" && (
    <img
      src="/images/wcats.png"
      alt="FA Wildcats"
      class="h-48 w-auto rounded-2xl bg-white/90 p-3 shadow-lg shadow-black/20"
    />
  )}
</div>   
      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {filteredTeams.map((team) => (
          <TeamCard team={team} />
        ))}
      </div>
   </section>
</PageShell>
</Layout>