---
import Layout from "../../layouts/Layout.astro";
import { sections } from "../../data/teams";
---

<Layout
  title="Teams | Wroughton & Wichelstowe FC"
  description="Explore football teams and pathways at Wroughton & Wichelstowe FC."
>
  <section class="bg-[#04163a] py-24 text-white">
    <div class="mx-auto max-w-6xl px-6">
      
      <div class="max-w-3xl">
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-blue-300">
          OUR FOOTBALL PATHWAYS
        </p>

        <h1 class="text-5xl font-light leading-tight tracking-tight sm:text-6xl">
          Teams & Football Opportunities
        </h1>

        <p class="mt-6 text-lg leading-relaxed text-slate-300">
          Wroughton & Wichelstowe FC provides inclusive football opportunities
          across youth, adult, girls, pan-disability and sessional football.
        </p>
      </div>

      <div class="mt-16 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {sections.map((section) => (
          <a
            href={`/teams/${section.slug}`}
            class="group rounded-3xl border border-white/10 bg-white/5 p-8 transition hover:border-blue-400/40 hover:bg-white/10"
          >
            <div class="flex h-full flex-col justify-between">
              
              <div>
                <h2 class="text-2xl font-semibold text-white transition group-hover:text-blue-300">
                  {section.title}
                </h2>

                <p class="mt-4 text-sm leading-relaxed text-slate-300">
                  {section.description}
                </p>
              </div>

              <div class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-blue-300">
                Explore teams
                <span aria-hidden="true">→</span>
              </div>

            </div>
          </a>
        ))}
      </div>

    </div>
  </section>
</Layout>