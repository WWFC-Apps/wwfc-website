---
import Layout from "../layouts/Layout.astro";
import PageShell from "../components/PageShell.astro";

const enquiryTypes = [
  "Joining a team",
  "Coaching or volunteering",
  "Safeguarding",
  "Sponsorship",
  "General club enquiry",
];
---

<Layout
  title="Contact | Wroughton & Wichelstowe FC"
  description="Contact Wroughton & Wichelstowe FC for team enquiries, volunteering, safeguarding, sponsorship and general club information."
>
  <PageShell>
    <section class="py-24">
      <div class="mx-auto max-w-6xl px-6">
        <div class="max-w-3xl">
          <p class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-blue-300">
            Contact WWFC
          </p>

          <h1 class="text-5xl font-light tracking-tight sm:text-6xl">
            Get in touch with the club.
          </h1>

          <p class="mt-6 text-lg leading-relaxed text-slate-300">
            Whether you’re interested in joining a team, volunteering, sponsoring the club,
            or asking a general question, we’d love to hear from you.
          </p>
        </div>

        <div class="mt-16 grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
          <form class="rounded-3xl border border-white/10 bg-white/5 p-8">
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label class="text-sm font-semibold text-white" for="name">
                  Name
                </label>
                <input
                  id="name"
                  name="name"
                  type="text"
                  class="mt-2 w-full rounded-xl border border-white/10 bg-white/10 px-4 py-3 text-white outline-none placeholder:text-slate-400 focus:border-blue-300"
                  placeholder="Your name"
                />
              </div>

              <div>
                <label class="text-sm font-semibold text-white" for="email">
                  Email
                </label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  class="mt-2 w-full rounded-xl border border-white/10 bg-white/10 px-4 py-3 text-white outline-none placeholder:text-slate-400 focus:border-blue-300"
                  placeholder="you@example.com"
                />
              </div>

              <div>
                <label class="text-sm font-semibold text-white" for="phone">
                  Phone
                </label>
                <input
                  id="phone"
                  name="phone"
                  type="tel"
                  class="mt-2 w-full rounded-xl border border-white/10 bg-white/10 px-4 py-3 text-white outline-none placeholder:text-slate-400 focus:border-blue-300"
                  placeholder="Optional"
                />
              </div>

              <div>
                <label class="text-sm font-semibold text-white" for="type">
                  Enquiry type
                </label>
                <select
                  id="type"
                  name="type"
                  class="mt-2 w-full rounded-xl border border-white/10 bg-white/10 px-4 py-3 text-white outline-none focus:border-blue-300"
                >
                  {enquiryTypes.map((type) => (
                    <option class="text-slate-950" value={type}>
                      {type}
                    </option>
                  ))}
                </select>
              </div>
            </div>

            <div class="mt-6">
              <label class="text-sm font-semibold text-white" for="message">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                class="mt-2 w-full rounded-xl border border-white/10 bg-white/10 px-4 py-3 text-white outline-none placeholder:text-slate-400 focus:border-blue-300"
                placeholder="Tell us how we can help..."
              ></textarea>
            </div>

            <label class="mt-6 flex gap-3 text-sm leading-relaxed text-slate-300">
              <input type="checkbox" class="mt-1 h-4 w-4 rounded" />
              <span>
                I understand WWFC will use this information to respond to my enquiry
                in line with the club’s privacy policy.
              </span>
            </label>

            <button
              type="button"
              class="mt-8 rounded-full bg-blue-500 px-6 py-3 font-semibold text-white shadow-lg shadow-blue-500/20 transition hover:scale-[1.02] hover:bg-blue-400"
            >
              Send enquiry
            </button>

            <p class="mt-4 text-sm text-slate-400">
              Form submission is not connected yet. This is the front-end placeholder.
            </p>
          </form>

          <aside class="space-y-6">
            <div class="rounded-3xl border border-white/10 bg-white/5 p-8">
              <h2 class="text-2xl font-semibold text-white">
                Safeguarding
              </h2>
              <p class="mt-4 text-slate-300">
                For safeguarding concerns, please contact the Club Welfare Officers directly.
              </p>
              <a
                href="mailto:wyfcwelfare@gmail.com"
                class="mt-5 inline-block font-semibold text-blue-300 hover:text-blue-200"
              >
                wyfcwelfare@gmail.com
              </a>
            </div>

            <div class="rounded-3xl border border-white/10 bg-white/5 p-8">
              <h2 class="text-2xl font-semibold text-white">
                Joining a team
              </h2>
              <p class="mt-4 text-slate-300">
                Please include the player’s school year, football experience and preferred pathway
                where possible.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-white/5 p-8">
              <h2 class="text-2xl font-semibold text-white">
                Club information
              </h2>
              <p class="mt-4 text-slate-300">
                Wroughton & Wichelstowe FC is a registered charity.
              </p>
              <p class="mt-3 text-slate-400">
                Charity Number: 1217495
              </p>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </PageShell>
</Layout>