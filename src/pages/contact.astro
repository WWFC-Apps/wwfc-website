---
import Layout from "../layouts/Layout.astro";
import PageShell from "../components/PageShell.astro";
---

<Layout title="Contact Us | Wroughton & Wichelstowe FC">
  <PageShell>
    <main class="mx-auto max-w-6xl px-6 py-20">
      <h1 class="text-4xl font-bold">Contact WWFC</h1>
      <p class="mt-6 max-w-3xl text-slate-300">
      Information about how to contact the club, including addresses, phone numbers, and email addresses, will be added here.
    </p>
  </main>
  </PageShell>
</Layout>