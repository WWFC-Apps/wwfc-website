---
import Layout from "../layouts/Layout.astro";
import PageShell from "../components/PageShell.astro";
---

<Layout
  title="Contact | Wroughton & Wichelstowe FC"
  description="Contact Wroughton & Wichelstowe FC for team enquiries, volunteering, safeguarding, sponsorship and general club information."
>
  <PageShell>
    <section class="py-24">
      <div class="mx-auto max-w-6xl px-6">
        <div class="max-w-3xl">
          <p class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-blue-300">
            Contact WWFC
          </p>

          <h1 class="text-5xl font-light tracking-tight sm:text-6xl">
            Get in touch with the club
          </h1>

          <p class="mt-6 text-lg leading-relaxed text-slate-300">
            Whether you’re interested in joining a team, volunteering,
            sponsorship opportunities or general club enquiries, we’d love to
            hear from you.
          </p>
        </div>

        <div class="mt-16 grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
         <div class="space-y-6">
  <div class="overflow-hidden rounded-3xl border border-white/10 bg-white/5">
    <iframe
      src="https://tally.so/r/rjGpQX"
      width="100%"
      height="900"
      frameborder="0"
      marginheight="0"
      marginwidth="0"
      title="WWFC Contact Form"
      class="w-full"
    ></iframe>
  </div>
  

  <div class="rounded-3xl border border-white/10 bg-white/5 p-8">
    <p class="text-sm font-semibold uppercase tracking-[0.3em] text-blue-300">
      Follow WWFC
    </p>

    <h2 class="mt-4 text-3xl font-light tracking-tight text-white">
      Follow the club on social media
    </h2>

    <p class="mt-4 max-w-2xl text-slate-300">
      Keep up to date with fixtures, club news, events, tournaments and team updates.
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href="https://www.facebook.com/WroughtonYFC/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-5 py-3 text-white transition hover:bg-white/10"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.5-3.88 3.77-3.88 1.09 0 2.22.2 2.22.2v2.45h-1.25c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12z"/>
        </svg>

        Facebook
      </a>

      <a
        href="https://www.instagram.com/wroughtonyouthfc/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-5 py-3 text-white transition hover:bg-white/10"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M7 2C4.24 2 2 4.24 2 7v10c0 2.76 2.24 5 5 5h10c2.76 0 5-2.24 5-5V7c0-2.76-2.24-5-5-5H7zm0 2h10c1.65 0 3 1.35 3 3v10c0 1.65-1.35 3-3 3H7c-1.65 0-3-1.35-3-3V7c0-1.65 1.35-3 3-3zm5 2.5A5.5 5.5 0 1 0 17.5 12 5.51 5.51 0 0 0 12 6.5zm0 2A3.5 3.5 0 1 1 8.5 12 3.5 3.5 0 0 1 12 8.5zm5.75-3.25a1.25 1.25 0 1 0 1.25 1.25 1.25 1.25 0 0 0-1.25-1.25z"/>
        </svg>

        Instagram
      </a>
    </div>
  </div>
</div>

          <aside class="space-y-6">
            <div class="rounded-3xl border border-white/10 bg-white/5 p-8">
              <h2 class="text-2xl font-semibold text-white">
                Safeguarding
              </h2>

              <p class="mt-4 text-slate-300">
                For safeguarding concerns, please contact the Club Welfare Officers directly.
              </p>

              <a
                href="mailto:wyfcwelfare@gmail.com"
                class="mt-5 inline-block font-semibold text-blue-300 hover:text-blue-200"
              >
                wyfcwelfare@gmail.com
              </a>
            </div>

            <div class="rounded-3xl border border-white/10 bg-white/5 p-8">
              <h2 class="text-2xl font-semibold text-white">
                Joining a Team
              </h2>

              <p class="mt-4 text-slate-300">
                Please include the player’s school year, football experience
                and preferred pathway where possible.
              </p>
            </div>

            <div class="rounded-3xl border border-white/10 bg-white/5 p-8">
              <h2 class="text-2xl font-semibold text-white">
                Privacy & Data
              </h2>

              <p class="mt-4 text-slate-300">
                WWFC handles personal information in accordance with our
                Privacy Policy and applicable UK GDPR requirements.
              </p>

              <a
                href="/policies/privacy-policy"
                class="mt-5 inline-block font-semibold text-blue-300 hover:text-blue-200"
              >
                View Privacy Policy →
              </a>
            </div>

            <div class="rounded-3xl border border-white/10 bg-white/5 p-8">
              <h2 class="text-2xl font-semibold text-white">
                Club Information
              </h2>

              <p class="mt-4 text-slate-300">
                Wroughton & Wichelstowe FC is a registered charity football club.
              </p>

              <p class="mt-3 text-slate-400">
                Charity Number: 1217495
              </p>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </PageShell>
</Layout>