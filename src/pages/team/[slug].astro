---
import Layout from "../../layouts/Layout.astro";
import PageShell from "../../components/PageShell.astro";
import {
  teams,
  getYouthAgeGroup,
  currentSeason,
} from "../../data/teams";

export function getStaticPaths() {
  return teams.map((team) => ({
    params: { slug: team.slug },
    props: { team },
  }));
}

const { team } = Astro.props;

const ageGroup = team.birthYear
  ? getYouthAgeGroup(team.birthYear)
  : null;
---

<Layout title={`${team.teamName} | Wroughton & Wichelstowe FC`}>
  <PageShell>
    <section class="mx-auto max-w-6xl px-6 py-20">
      <a href="/teams" class="text-sm font-semibold text-blue-300 hover:text-blue-200">
        ← Back to teams
      </a>

      {ageGroup && (
        <p class="mt-10 text-sm font-medium uppercase tracking-[0.3em] text-blue-300">
          {ageGroup} • Season {currentSeason.label}
        </p>
      )}

      <h1 class="mt-4 text-5xl font-light tracking-tight text-white">
        {ageGroup ? `${ageGroup} ${team.teamName}` : team.teamName}
      </h1>

      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-slate-300">
        {team.description}
      </p>

      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
          <h2 class="font-semibold text-white">Manager / Coach</h2>
          <p class="mt-2 text-slate-300">{team.manager}</p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
          <h2 class="font-semibold text-white">Training</h2>
          <p class="mt-2 text-slate-300">{team.training}</p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
          <h2 class="font-semibold text-white">Venue</h2>
          <p class="mt-2 text-slate-300">{team.venue}</p>
        </div>
      </div>
{team.contactEmail && (
  <div class="mt-6 rounded-2xl border border-white/10 bg-white/5 p-6">
    <h2 class="font-semibold text-white">Contact</h2>

    <a
      href={`mailto:${team.contactEmail}`}
      class="mt-2 inline-block text-blue-300 hover:text-blue-200"
    >
      {team.contactEmail}
    </a>
  </div>
)}
      <section class="mt-10 rounded-2xl border border-white/10 bg-white/5 p-6">
  <h2 class="text-xl font-semibold text-white">Team Gallery</h2>

  {team.gallery && team.gallery.length > 0 ? (
    <div class="mt-6 grid gap-4 sm:grid-cols-2 md:grid-cols-3">
      {team.gallery.map((image) => (
        <img
          src={image}
          alt={`${team.teamName} team photo`}
          class="h-64 w-full rounded-2xl object-cover"
        />
      ))}
    </div>
  ) : (
    <p class="mt-3 text-slate-300">
      Photos for this team will be added soon.
    </p>
  )}
</section>

      <div class="mt-10 rounded-2xl border border-blue-400/20 bg-blue-500/10 p-6">
        {team.sponsorName && (
  <section class="mt-10 rounded-2xl border border-white/10 bg-white/5 p-6">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-300">
      Team Sponsor
    </p>

    <div class="mt-5 flex flex-col gap-5 sm:flex-row sm:items-center">
      {team.sponsorLogo && (
        <img
          src={team.sponsorLogo}
          alt={`${team.sponsorName} logo`}
          class="h-20 w-auto rounded-xl bg-white/90 p-2"
        />
      )}

      <div>
        <h2 class="text-2xl font-semibold text-white">
          {team.sponsorName}
        </h2>

        {team.sponsorDescription && (
          <p class="mt-3 text-slate-300">
            {team.sponsorDescription}
          </p>
        )}

        {team.sponsorUrl && (
          <a
            href={team.sponsorUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex font-semibold text-blue-300 hover:text-blue-200"
          >
           <a
  href={team.sponsorUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="mt-4 inline-flex font-semibold text-blue-300 hover:text-blue-200"
>
  {team.teamName === "Wildcats"
    ? "Book sessions →"
    : "Visit sponsor website →"}
</a>
          </a>
        )}
      </div>
    </div>
  </section>
)}
        <h2 class="text-xl font-semibold text-white">Interested in joining?</h2>
        <p class="mt-3 text-slate-300">
          Contact the club to ask about availability for this team.
        </p>

        <a
          href="/contact"
          class="mt-5 inline-flex rounded-full bg-blue-500 px-6 py-3 font-semibold text-white shadow-lg shadow-blue-500/20 transition hover:scale-[1.02] hover:bg-blue-400"
        >
          Contact us
        </a>
      </div>
    </section>
  </PageShell>
</Layout>